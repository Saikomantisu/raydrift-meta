{
  "name": "raydrift-meta",
  "version": "0.2.1",
  "private": false,
  "type": "module",
  "description": "SEO-first Astro components with Schema.org JSON-LD helpers",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Saikomantisu/raydrift-meta.git",
    "directory": "packages/primitives"
  },
  "keywords": [
    "astro",
    "seo",
    "schema.org",
    "json-ld",
    "meta-tags"
  ],
  "bin": {
    "raydrift-meta": "./bin/raydrift-meta.cjs"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "astro": "^5.17.1",
    "typescript": "^5.9.3"
  },
  "exports": {
    ".": "./src/index.ts",
    "./seo": "./src/components/seo/index.ts",
    "./seo/*": "./src/components/seo/*"
  },
  "files": [
    "src/**",
    "bin/**",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "astro check && tsc --noEmit",
    "prepublishOnly": "pnpm --filter raydrift-meta typecheck"
  }
}
