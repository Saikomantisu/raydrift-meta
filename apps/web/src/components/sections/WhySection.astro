---
import CodeWindow from './CodeWindow.astro';

export interface Props {
  title?: string;
  subtitle?: string;
  description?: string;
}

const {
  title = 'Why Raydrift Meta?',
  subtitle = 'Schema-first, visual-second',
  description = 'Most libraries focus on visual polish while ignoring the fundamentals of search optimization. Raydrift Meta is a library of Schema Elements. Every element is designed with semantic HTML5, proper heading hierarchy, and Schema.org structured data from the ground up.',
} = Astro.props;

const features = [
  {
    icon: 'check',
    iconColor: 'cyan',
    title: 'Proper HTML5 semantics throughout',
    description: 'Headings, landmarks, and markup are first-class.',
  },
  {
    icon: 'check',
    iconColor: 'fuchsia',
    title: 'Schema.org JSON-LD structured data',
    description: 'Rich results, knowledge panels, and clarity.',
  },
  {
    icon: 'check',
    iconColor: 'emerald',
    title: 'WCAG 2.1 AA accessibility compliance',
    description: 'Keyboard, contrast, and screen-reader ready.',
  },
  {
    icon: 'check',
    iconColor: 'amber',
    title: 'Zero JavaScript by default',
    description: 'Only ship what you activate.',
  },
];
---

<section
  class="why-section py-32 border-t border-stone-800"
  aria-labelledby="why-raydrift-title"
>
  <div
    class="rd-container flex flex-col lg:flex-row gap-12 lg:gap-20 items-center"
  >
    <div class="space-y-8 lg:flex-1">
      <div>
        <h2
          id="why-raydrift-title"
          class="text-sm tracking-[0.2em] uppercase text-stone-500 mb-4"
        >
          {title}
        </h2>
        <p
          class="font-display text-3xl md:text-4xl font-bold text-white leading-tight mb-6"
        >
          {subtitle}
        </p>
        <p class="text-lg text-stone-400 leading-relaxed">
          {description}
        </p>
      </div>

      <div class="grid sm:grid-cols-2 gap-6">
        {
          features.map((feature) => (
            <div class="why-card border border-stone-800/80 bg-stone-900/40 rounded-2xl p-5 h-full flex flex-col gap-2">
              <div
                class={`why-icon bg-${feature.iconColor}-500/10 text-${feature.iconColor}-300 border border-${feature.iconColor}-500/20`}
                aria-hidden="true"
              >
                {feature.icon === 'check' && (
                  <svg
                    class="w-4 h-4"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M5 13l4 4L19 7"
                    />
                  </svg>
                )}
                {feature.icon === 'clock' && (
                  <svg
                    class="w-4 h-4"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M12 8v4l3 3"
                    />
                  </svg>
                )}
                {feature.icon === 'check-circle' && (
                  <svg
                    class="w-4 h-4"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M9 12l2 2 4-4"
                    />
                  </svg>
                )}
                {feature.icon === 'zap' && (
                  <svg
                    class="w-4 h-4"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M12 6v6l4 2"
                    />
                  </svg>
                )}
              </div>
              <p class="text-sm text-stone-200 font-semibold">
                {feature.title}
              </p>
              <p class="text-xs text-stone-400">{feature.description}</p>
            </div>
          ))
        }
      </div>
    </div>

    <div class="relative min-w-0 lg:flex-1">
      <div
        class="absolute -top-6 -right-6 w-32 h-32 rounded-full bg-cyan-500/10 blur-2xl"
        aria-hidden="true"
      >
      </div>
      <CodeWindow />
    </div>
  </div>
</section>

<style>
  .why-card {
    backdrop-filter: blur(6px);
    transition:
      transform 0.2s ease,
      border-color 0.2s ease;
  }

  .why-card:hover {
    transform: translateY(-3px);
    border-color: rgba(148, 163, 184, 0.5);
  }

  .why-icon {
    width: 34px;
    height: 34px;
    border-radius: 12px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 12px;
  }
</style>
