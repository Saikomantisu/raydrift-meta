---
import { COMPANY_NAME, NAV_LINKS } from '@/constants';
---

<nav
  class="fixed top-8 left-1/2 -translate-x-1/2 z-100 w-[min(92vw,48rem)]"
  id="navbar"
  aria-label="Primary"
>
  <div
    class="relative rounded-3xl bg-stone-900/95 backdrop-blur-xl border border-stone-700/50 shadow-2xl opacity-0 translate-y-[-20px] overflow-hidden"
    id="navbar-inner"
  >
    <div
      class="grid grid-cols-[1fr_auto_1fr] md:grid-cols-3 items-center px-5 py-3"
    >
      <a
        href="/"
        class="font-display text-lg font-bold text-white hover:opacity-80 transition-opacity duration-150 justify-self-start"
      >
        {COMPANY_NAME}
      </a>

      <!-- Desktop links -->
      <div class="hidden md:flex items-center justify-center gap-6" role="list">
        {
          NAV_LINKS.map((link) => (
            <a
              href={link.href as string}
              class="relative text-sm text-stone-400 hover:text-white transition-colors duration-150 group"
              role="listitem"
            >
              <span>{link.label}</span>
              <span class="absolute -bottom-1 left-0 w-0 h-px bg-stone-400 group-hover:w-full transition-all duration-200 ease-out" />
            </a>
          ))
        }
      </div>

      <!-- Desktop CTA -->
      <a
        href="#"
        class="hidden md:inline-flex text-sm font-medium text-stone-950 bg-white px-4 py-1.5 rounded-full hover:bg-stone-200 transition-colors duration-150 justify-self-end"
      >
        Get Started
      </a>

      <!-- Mobile toggle -->
      <button
        type="button"
        id="navbar-toggle"
        class="md:hidden col-start-3 justify-self-end w-10 h-10 rounded-full border border-stone-700/60 flex items-center justify-center text-stone-300 hover:text-white hover:border-stone-500 transition-all duration-200"
        aria-expanded="false"
        aria-controls="navbar-panel"
        aria-label="Open menu"
      >
        <svg
          id="icon-menu"
          class="w-5 h-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
        <svg
          id="icon-close"
          class="w-5 h-5 hidden"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <!-- Mobile panel (slides down) -->
    <div
      id="navbar-panel"
      class="md:hidden top overflow-hidden transition-all duration-300 ease-out relative bg-stone-900/95"
      style="max-height: 0px; opacity: 0; pointer-events: none;"
      aria-hidden="true"
    >
      <div class="px-5 pb-5 pt-1 border-t border-stone-800/60">
        <div class="flex flex-col gap-1" role="list">
          {
            NAV_LINKS.map((link) => (
              <a
                href={link.href as string}
                class="text-base text-stone-300 hover:text-white transition-colors duration-150 py-3 px-2 rounded-xl hover:bg-stone-800/60"
                data-nav-link
                role="listitem"
              >
                {link.label}
              </a>
            ))
          }
        </div>

        <a
          href="#"
          class="mt-4 inline-flex w-full items-center justify-center text-sm font-medium text-stone-950 bg-white px-4 py-3 rounded-xl hover:bg-stone-200 transition-colors duration-150"
        >
          Get Started
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  import { animate } from 'framer-motion';

  const navbarInner = document.getElementById('navbar-inner');
  const toggleBtn = document.getElementById(
    'navbar-toggle'
  ) as HTMLButtonElement | null;
  const panel = document.getElementById('navbar-panel');
  const focusableSelector =
    'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])';
  const iconMenu = document.getElementById('icon-menu');
  const iconClose = document.getElementById('icon-close');
  const navLinks = document.querySelectorAll('[data-nav-link]');

  let isOpen = false;

  // Initial reveal animation
  if (navbarInner) {
    animate(
      navbarInner,
      { opacity: 1, y: 0 },
      { duration: 0.5, ease: [0.4, 0, 0.2, 1] }
    );
  }

  function updatePanelState() {
    if (!panel || !toggleBtn || !iconMenu || !iconClose) return;
    if (isOpen) {
      panel.style.maxHeight = panel.scrollHeight + 'px';
      panel.style.opacity = '1';
      panel.style.pointerEvents = 'auto';
      panel.removeAttribute('aria-hidden');
      iconMenu.classList.add('hidden');
      iconClose.classList.remove('hidden');
      toggleBtn.setAttribute('aria-expanded', 'true');
      toggleBtn.setAttribute('aria-label', 'Close menu');
      const focusables = panel.querySelectorAll<HTMLElement>(focusableSelector);
      if (focusables.length) focusables[0].focus();
    } else {
      panel.style.maxHeight = '0px';
      panel.style.opacity = '0';
      panel.style.pointerEvents = 'none';
      panel.setAttribute('aria-hidden', 'true');
      iconMenu.classList.remove('hidden');
      iconClose.classList.add('hidden');
      toggleBtn.setAttribute('aria-expanded', 'false');
      toggleBtn.setAttribute('aria-label', 'Open menu');
    }
  }

  function closePanel() {
    if (!isOpen) return;
    isOpen = false;
    updatePanelState();
    toggleBtn?.focus();
  }

  if (toggleBtn) {
    toggleBtn.addEventListener('click', () => {
      isOpen = !isOpen;
      updatePanelState();
    });
  }

  // Close on nav link click
  navLinks.forEach((link) => {
    link.addEventListener('click', closePanel);
  });

  // Close on Escape and trap focus when open
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closePanel();
    if (!isOpen || !panel) return;
    if (e.key !== 'Tab') return;
    const focusables = panel.querySelectorAll<HTMLElement>(focusableSelector);
    if (!focusables.length) return;
    const first = focusables[0];
    const last = focusables[focusables.length - 1];
    if (e.shiftKey && document.activeElement === first) {
      e.preventDefault();
      last.focus();
    } else if (!e.shiftKey && document.activeElement === last) {
      e.preventDefault();
      first.focus();
    }
  });

  // Close when clicking outside
  document.addEventListener('click', (e) => {
    const navbar = document.getElementById('navbar');
    if (!navbar) return;
    if (!navbar.contains(e.target as Node)) {
      closePanel();
    }
  });
</script>
