---
import {
  COMPANY_NAME,
  FOOTER_TAGLINE,
  FOOTER_LINK_GROUPS,
  SOCIAL_LINKS,
  COPYRIGHT_TEXT,
} from '@/constants';
---

<footer class="bg-stone-950 border-t border-stone-800 relative overflow-hidden">
  <!-- Gradient accent line at top -->
  <div
    class="absolute top-0 left-0 right-0 h-px bg-linear-to-r from-cyan-400 via-fuchsia-400 to-yellow-400"
  >
  </div>

  <!-- Main footer content -->
  <div class="rd-container pt-20 pb-8">
    <!-- Top section: Company info + Link grid -->
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-8 mb-20">
      <!-- Company description -->
      <div class="lg:col-span-5">
        <p class="font-display text-2xl font-bold text-white mb-4">
          {COMPANY_NAME}
        </p>
        <p class="text-stone-400 text-base leading-relaxed max-w-md mb-6">
          {FOOTER_TAGLINE}
        </p>
        <nav class="flex items-center gap-4" aria-label="Social links">
          <a
            href={SOCIAL_LINKS.github.href}
            class="w-10 h-10 rounded-full border border-stone-700 flex items-center justify-center text-stone-400 hover:text-white hover:border-stone-500 hover:scale-110 transition-all duration-200"
            aria-label={SOCIAL_LINKS.github.ariaLabel}
          >
            <svg
              class="w-4 h-4"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
              ></path>
            </svg>
          </a>
          <a
            href={SOCIAL_LINKS.discord.href}
            class="w-10 h-10 rounded-full border border-stone-700 flex items-center justify-center text-stone-400 hover:text-white hover:border-stone-500 hover:scale-110 transition-all duration-200"
            aria-label={SOCIAL_LINKS.discord.ariaLabel}
          >
            <svg
              class="w-4 h-4"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028 14.09 14.09 0 001.226-1.994.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"
              ></path>
            </svg>
          </a>
        </nav>
      </div>

      <!-- Link columns -->
      <div class="lg:col-span-7 grid grid-cols-3 gap-8" role="list">
        {
          FOOTER_LINK_GROUPS.map((group) => (
            <div role="listitem">
              <h4 class="text-white font-semibold text-sm mb-4 tracking-wide">
                {group.title}
              </h4>
              <ul class="space-y-3" role="list">
                {group.links.map((link) => (
                  <li role="listitem">
                    <a
                      href={link.href}
                      class="text-stone-500 text-sm hover:text-white transition-colors duration-150 inline-flex items-center gap-1 group"
                    >
                      <span>{link.label}</span>
                      <svg
                        class="w-3 h-3 opacity-0 -translate-x-1 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-150"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        aria-hidden="true"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M9 5l7 7-7 7"
                        />
                      </svg>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Large watermark -->
    <div
      class="w-full overflow-hidden py-6 md:py-8 border-t border-stone-800/50"
    >
      <p
        class="font-display text-[12vw] md:text-[10vw] font-bold text-white leading-none text-center whitespace-nowrap select-none"
      >
        {COMPANY_NAME}
      </p>
    </div>

    <!-- Bottom bar -->
    <div
      class="flex flex-col md:flex-row justify-between items-center gap-4 pt-8 border-t border-stone-800/50"
    >
      <p class="text-stone-600 text-sm">{COPYRIGHT_TEXT.line1}</p>
      <p class="text-stone-600 text-sm">{COPYRIGHT_TEXT.line2}</p>
    </div>
  </div>
</footer>
