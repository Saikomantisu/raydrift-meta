---
import DocsContentLayout from '@/layouts/DocsContentLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const toSlug = (id: string) => id.replace(/\.(md|mdx)$/, '');
  const entries = await getCollection('docs');
  return entries
    .filter((entry) => toSlug(entry.id) !== 'index')
    .map((entry) => ({
      params: { slug: toSlug(entry.id) },
      props: { slug: toSlug(entry.id) },
    }));
}

const toSlug = (id: string) => id.replace(/\.(md|mdx)$/, '');

const { slug } = Astro.props;
if (slug === 'index') {
  return Astro.redirect('/docs');
}

const entries = await getCollection('docs');
const entry = entries.find((item) => toSlug(item.id) === slug);

if (!entry) {
  return Astro.redirect('/docs');
}

const { Content } = await render(entry);
---

<DocsContentLayout
  title={entry.data.title}
  description={entry.data.description}
>
  <Content />
</DocsContentLayout>
