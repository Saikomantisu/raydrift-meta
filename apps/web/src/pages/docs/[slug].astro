---
import DocsContentLayout from '@/layouts/DocsContentLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('docs');
  return entries
    .filter((entry) => entry.slug !== 'index')
    .map((entry) => ({
      params: { slug: entry.slug },
      props: { slug: entry.slug },
    }));
}

const { slug } = Astro.props;
if (slug === 'index') {
  return Astro.redirect('/docs');
}

const entries = await getCollection('docs');
const entry = entries.find((item) => item.slug === slug);

if (!entry) {
  return Astro.redirect('/docs');
}

const { Content } = await entry.render();
---

<DocsContentLayout title={entry.data.title} description={entry.data.description}>
  <Content />
</DocsContentLayout>
