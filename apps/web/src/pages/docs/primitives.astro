---
import DocsContentLayout from '@/layouts/DocsContentLayout.astro';

const primitives = [
  {
    title: 'SEOHead',
    description: 'Meta tags, OpenGraph, and Twitter cards.',
    href: '/docs/seohead',
    category: 'Metadata',
    detail: 'Head tags + social previews',
  },
  {
    title: 'ArticleSchema',
    description: 'JSON-LD for Schema.org Article.',
    href: '/docs/articleschema',
    category: 'Structured Data',
    detail: 'Publisher, author, dates',
  },
  {
    title: 'Breadcrumbs',
    description: 'Visual breadcrumbs + BreadcrumbList JSON-LD.',
    href: '/docs/breadcrumbs',
    category: 'Navigation',
    detail: 'ListItem + hierarchy',
  },
  {
    title: 'FAQSchema',
    description: 'JSON-LD for FAQPage content.',
    href: '/docs/faqschema',
    category: 'Structured Data',
    detail: 'Question + Answer pairs',
  },
];
---

<DocsContentLayout
  title="Primitives"
  description="Explore every Raydrift Meta primitive."
>
  <section class="primitives-hero" aria-labelledby="primitives-title">
    <div class="primitives-hero-meta">
      <p class="primitives-eyebrow">Raydrift Meta</p>
      <h1 id="primitives-title" class="primitives-title">Primitives</h1>
      <p class="primitives-subtitle">
        A focused catalog of schema elements. Each primitive is designed to be
        dropped into a page or layout and leave behind clean, validated markup.
      </p>
      <div class="primitives-stats">
        <div class="stat-card">
          <span class="stat-label">Available</span>
          <span class="stat-value">{primitives.length}</span>
        </div>
        <div class="stat-card">
          <span class="stat-label">Categories</span>
          <span class="stat-value">3</span>
        </div>
      </div>
    </div>
    <div class="primitives-hero-panel" aria-hidden="true">
      <div class="panel-ring"></div>
      <div class="panel-ring ring-2"></div>
      <div class="panel-card">
        <p class="panel-label">Schema Focus</p>
        <p class="panel-title">Structured data first</p>
        <p class="panel-copy">
          Each primitive outputs JSON-LD aligned with Schema.org definitions.
        </p>
      </div>
    </div>
  </section>

  <section class="primitives-grid" aria-label="Primitive list">
    {primitives.map((item, index) => (
      <a class="primitive-card" href={item.href} style={{ '--delay': `${index * 0.06}s` }}>
        <div class="card-top">
          <span class="card-index">0{index + 1}</span>
          <span class="card-tag">{item.category}</span>
        </div>
        <h2 class="card-title">{item.title}</h2>
        <p class="card-desc">{item.description}</p>
        <div class="card-meta">
          <span class="card-detail">{item.detail}</span>
        </div>
        <span class="card-link">Read docs →</span>
      </a>
    ))}
  </section>

  <style>
    .primitives-hero {
      display: grid;
      grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
      gap: 28px;
      padding: 32px;
      border-radius: 32px;
      border: 1px solid rgba(87, 83, 78, 0.6);
      background:
        radial-gradient(
          circle at 20% 20%,
          rgba(56, 189, 248, 0.12),
          transparent 45%
        ),
        linear-gradient(140deg, rgba(20, 20, 22, 0.95), rgba(12, 10, 9, 0.75));
      position: relative;
      overflow: hidden;
    }

    .primitives-hero::after {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(
        circle at 80% 20%,
        rgba(251, 191, 36, 0.08),
        transparent 40%
      );
      pointer-events: none;
    }

    .primitives-hero-meta {
      display: grid;
      gap: 14px;
      z-index: 1;
    }

    .primitives-eyebrow {
      text-transform: uppercase;
      letter-spacing: 0.3em;
      font-size: 11px;
      color: #a8a29e;
      margin: 0;
    }

    .primitives-title {
      font-size: clamp(2.6rem, 3.5vw, 3.4rem);
      margin: 0;
      color: #fff;
    }

    .primitives-subtitle {
      margin: 0;
      color: #d6d3d1;
      max-width: 560px;
      line-height: 1.7;
    }

    .primitives-stats {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
    }

    .stat-card {
      display: grid;
      gap: 4px;
      padding: 12px 14px;
      border-radius: 14px;
      border: 1px solid rgba(120, 113, 108, 0.5);
      background: rgba(12, 10, 9, 0.6);
      min-width: 120px;
    }

    .stat-label {
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: #a8a29e;
    }

    .stat-value {
      font-size: 1.6rem;
      color: #fff;
      font-weight: 600;
    }

    .primitives-hero-panel {
      position: relative;
      border-radius: 26px;
      border: 1px solid rgba(63, 63, 70, 0.6);
      background: rgba(12, 10, 9, 0.7);
      overflow: hidden;
      min-height: 220px;
    }

    .panel-ring {
      position: absolute;
      width: 200px;
      height: 200px;
      border-radius: 50%;
      border: 1px solid rgba(56, 189, 248, 0.35);
      top: -40px;
      right: -60px;
      box-shadow: 0 0 40px rgba(56, 189, 248, 0.2);
    }

    .panel-ring.ring-2 {
      width: 260px;
      height: 260px;
      top: -80px;
      right: -100px;
      border-color: rgba(251, 191, 36, 0.25);
    }

    .panel-card {
      position: absolute;
      left: 18px;
      bottom: 18px;
      padding: 16px;
      border-radius: 18px;
      border: 1px solid rgba(87, 83, 78, 0.6);
      background: rgba(20, 20, 22, 0.9);
      max-width: 230px;
    }

    .panel-label {
      text-transform: uppercase;
      letter-spacing: 0.2em;
      font-size: 10px;
      color: #a8a29e;
      margin: 0 0 8px;
    }

    .panel-title {
      margin: 0 0 6px;
      font-size: 1.05rem;
      color: #fff;
    }

    .panel-copy {
      margin: 0;
      color: #d6d3d1;
      font-size: 0.9rem;
      line-height: 1.5;
    }

    .primitives-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 18px;
    }

    .primitive-card {
      display: grid;
      gap: 12px;
      padding: 20px;
      border-radius: 22px;
      border: 1px solid rgba(87, 83, 78, 0.55);
      background: rgba(12, 10, 9, 0.65);
      text-decoration: none;
      color: inherit;
      transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
      position: relative;
      overflow: hidden;
      animation: rise 0.5s ease both;
      animation-delay: var(--delay);
    }

    .primitive-card::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(
        120deg,
        rgba(56, 189, 248, 0.08),
        transparent 60%
      );
      opacity: 0;
      transition: opacity 0.2s ease;
    }

    .primitive-card:hover {
      transform: translateY(-3px);
      border-color: rgba(120, 113, 108, 0.85);
      box-shadow: 0 20px 40px -30px rgba(0, 0, 0, 0.8);
    }

    .primitive-card:hover::after {
      opacity: 1;
    }

    .card-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
    }

    .card-index {
      font-size: 12px;
      letter-spacing: 0.2em;
      color: #a8a29e;
      text-transform: uppercase;
    }

    .card-tag {
      font-size: 11px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #e7e5e4;
      padding: 4px 8px;
      border-radius: 999px;
      border: 1px solid rgba(63, 63, 70, 0.7);
      background: rgba(20, 20, 22, 0.8);
    }

    .card-title {
      margin: 0;
      font-size: 1.35rem;
      color: #fff;
    }

    .card-desc {
      margin: 0;
      color: #d6d3d1;
      line-height: 1.6;
    }

    .card-meta {
      display: flex;
      align-items: center;
      justify-content: space-between;
      font-size: 0.9rem;
      color: #a8a29e;
    }

    .card-link {
      color: #f5f5f4;
      font-size: 0.9rem;
      align-self: flex-start;
    }

    @keyframes rise {
      from {
        opacity: 0;
        transform: translateY(10px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @media (max-width: 960px) {
      .primitives-hero {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 640px) {
      .primitives-hero {
        padding: 22px;
      }

      .primitives-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</DocsContentLayout>
